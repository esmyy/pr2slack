{
  "name": "@esmyy/pr2slack",
  "private": false,
  "version": "1.0.12",
  "description": "Send current GitHub pull request to Slack via incoming webhook",
  "type": "module",
  "main": "pr2slack.js",
  "scripts": {
    "start": "node pr2slack.js",
    "check": "node pr2slack.js --help",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "release": "npm run version:patch && npm publish",
    "release:patch": "npm run version:patch && npm publish",
    "release:minor": "npm run version:minor && npm publish",
    "release:major": "npm run version:major && npm publish"
  },
  "bin": {
    "pr2slack": "./pr2slack.js"
  },
  "keywords": [
    "slack",
    "pr",
    "notification"
  ],
  "author": "esmyy",
  "repository": {
    "type": "git",
    "url": "https://github.com/esmyy/pr2slack.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {},
  "packageManager": "pnpm@10.28.0",
  "dependencies": {}
}
